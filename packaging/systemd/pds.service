[Unit]
# Per-user pds, run under the user's own session manager:
#   systemctl --user enable --now pds
# Runs as the logged-in user, reading host keys from ~/.ssh/id_* and config from
# ~/.config/pds/server (plus the /etc and /usr/lib tiers).
Description=PDS server (pds)
Documentation=https://petris.dev/pds

[Service]
Type=simple
ExecStart=/usr/bin/pdsd
Restart=on-failure
RestartSec=2

# --- Hardening (subset that works under the user manager) ---
NoNewPrivileges=yes
PrivateTmp=yes

[Install]
WantedBy=default.target
